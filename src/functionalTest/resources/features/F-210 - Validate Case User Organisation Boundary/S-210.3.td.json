{
  "_guid_": "S-210.3",
  "_extends_": "F-210-Base",
  "title": "Must return 400 when POST /case-users omits organisation_id",

  "specs": [
    "CAA - with a PRD organisation",
    "intends to add a valid case-user assignment",
    "contains a valid case-user assignment without organisation_id"
  ],

  "prerequisites": [
    {
      "Create_Case": "F-210_Prerequisite_Case_Creation_All_To_Org1"
    }
  ],

  "request": {
    "_extends_": "Common_Request",
    "body": {
      "case_users": [
        {
          "case_id": "${[scenarioContext][childContexts][Create_Case][testData][actualResponse][body][id]}",
          "case_role": "[ApplicantSolicitor]",
          "user_id": "${[scenarioContext][testData][users][invokingUser][id]}"
        }
      ]
    }
  },

  "expectedResponse": {
    "_extends_": "ACA_400_Response",
    "body": {
      "message": "Invalid data provided for the following inputs to the request:\nOrganisation ID is not valid",
      "errors": []
    }
  }
}
